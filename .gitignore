# =============================================================================
# .gitignore for C++ String Encryption Library
# =============================================================================

# =============================================================================
# Build artifacts
# =============================================================================
*.o
*.obj
*.so
*.dylib
*.dll
*.a
*.lib
*.exe
*.out
*.app
*.dSYM/
*.su
*.idb
*.pdb

# =============================================================================
# Compiled binaries
# =============================================================================
test_*
*_test
*_test_*
*_bench
*_example
inspect_*
decryptor
verify_*
demo

# =============================================================================
# C++ specific
# =============================================================================
*.gcda
*.gcno
*.gcov
*.hpp.gch
*.h.gch

# =============================================================================
# Xcode
# =============================================================================
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
*.moved-aside
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3

# =============================================================================
# CLion / IDEA
# =============================================================================
.idea/
cmake-build-*/
*.iml
*.iws
*.ipr

# =============================================================================
# Visual Studio Code
# =============================================================================
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# =============================================================================
# CMake
# =============================================================================
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt
!cmake/

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*

# =============================================================================
# Linux
# =============================================================================
*~
.directory
.Trash-*

# =============================================================================
# Windows
# =============================================================================
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# =============================================================================
# Debugging / Profiling
# =============================================================================
*.log
*.trace
llldb*
*.lldb
gdb.txt
gdb_history

# =============================================================================
# Sanitizers
# =============================================================================
*.asan
*.msan
*.lsan
*.tsan
*.ubsan

# =============================================================================
# Coverage
# =============================================================================
coverage/
*.coveragerc
coverage.info
lcov.info

# =============================================================================
# Documentation (if using separate tools)
# =============================================================================
doxygen/
html/
latex/

# =============================================================================
# Temporary files
# =============================================================================
*.swp
*.swo
*~
.*.swp
.*.swo
.vim/
.netrwhist

# =============================================================================
# Backup files
# =============================================================================
*.bak
*.backup
*.tmp
*.temp

# =============================================================================
# Package managers
# =============================================================================
vendor/
node_modules/

# =============================================================================
# Archives
# =============================================================================
*.zip
*.tar
*.tar.gz
*.tar.xz
*.rar
*.7z

# =============================================================================
# Security (keep encrypted but ignore keys)
# =============================================================================
*.key
*.pem
*.p12
*.pfx
secrets/
.env
!.env.example

# =============================================================================
# Test outputs
# =============================================================================
test_output/
results/
*.out
*.err

# =============================================================================
# Performance benchmarks
# =============================================================================
benchmark_results/
*.bench

.claude/skills/scitools-understand/

.claude/skills/compliance-checker/

compliance_output/misra/

.claude/skills/architecture-analyzer/

stringo.und/
